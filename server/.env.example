# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/reimbursement_db?schema=public"

# JWT
JWT_SECRET="super_secret_jwt_key_reimbursement_system_123"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV="development"

# SMTP (Email) - Using a console logger approach initially, modify with actual credentials later
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@reimbursement.com"

# External APIs
COUNTRIES_API_URL="https://restcountries.com/v3.1/all?fields=name,currencies"
EXCHANGE_RATE_API_URL="https://api.exchangerate-api.com/v4/latest"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

EXCHANGE_RATE_CACHE_TTL=3600
